# =============================================
# GUSTO DEMO API
# =============================================
GUSTO_API_BASE_URL=https://api.gusto-demo.com
GUSTO_API_VERSION=2025-11-15
GUSTO_BEARER_TOKEN=YOUR_GUSTO_BEARER_TOKEN
GUSTO_EMPLOYEE_UUID=c3dd05c3-86aa-43e9-8f2d-c8832f5c5ae8

# =============================================
# RECLAIM PROTOCOL (zkFetch)
# Get from: https://dev.reclaimprotocol.org
# Create a "zkFetch" application type
# Enable zkFetch in the Integration tab
# =============================================
RECLAIM_APP_ID=YOUR_RECLAIM_APP_ID_HERE
RECLAIM_APP_SECRET=YOUR_RECLAIM_APP_SECRET_HERE

# =============================================
# XION TESTNET
# =============================================
XION_RPC_URL=https://rpc.xion-testnet-2.burnt.com:443
XION_REST_URL=https://api.xion-testnet-2.burnt.com
XION_CHAIN_ID=xion-testnet-2

XION_BACKEND_MNEMONIC=your twelve word mnemonic phrase here for testnet wallet
XION_BACKEND_ADDRESS=xion1yourtestnetaddresshere

# Fill in after contract deployment:
ZKPAY_CONTRACT_ADDRESS=PLACEHOLDER_DEPLOY_FIRST
BB_VERIFIER_MODULE_ADDRESS=xion1barretenbergverifieraddresshere
TREASURY_ADDRESS=xion1yourtreasuryfundedaddresshere

# =============================================
# CIRCUIT
# =============================================
NARGO_WORKSPACE_PATH=../circuit
VKEY_HASH=PLACEHOLDER_COMPUTE_AFTER_COMPILE

# =============================================
# CLAIM PARAMETERS (all in CENTS / u64)
# =============================================
INCOME_THRESHOLD_CENTS=300000
MAX_AUTO_PAYOUT_CENTS=500000
MAX_PAY_STUB_AGE_DAYS=90

# =============================================
# BACKEND SERVER
# =============================================
PORT=3001
FRONTEND_URL=http://localhost:3000
